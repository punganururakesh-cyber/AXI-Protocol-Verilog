module axi_master (
    
    input  wire        ACLK,
    input  wire        ARESETn,

    
    output reg  [31:0] AWADDR,
    output reg         AWVALID,
    input  wire        AWREADY,

    
    output reg  [31:0] WDATA,
    output reg  [3:0]  WSTRB,
    output reg         WVALID,
    input  wire        WREADY,

   
    input  wire [1:0]  BRESP,
    input  wire        BVALID,
    output reg         BREADY,

    
    output reg  [31:0] ARADDR,
    output reg         ARVALID,
    input  wire        ARREADY,

    
    input  wire [31:0] RDATA,
    input  wire [1:0]  RRESP,
    input  wire        RVALID,
    output reg         RREADY,

   
    input  wire        start_write,
    input  wire        start_read,
    input  wire [31:0] addr_in,
    input  wire [31:0] data_in,
    output reg  [31:0] data_out,
    output reg         done
);

   
    localparam IDLE       = 3'd0;
    localparam WR_ADDR    = 3'd1;
    localparam WR_DATA    = 3'd2;
    localparam WR_RESP    = 3'd3;
    localparam RD_ADDR    = 3'd4;
    localparam RD_DATA    = 3'd5;

    reg [2:0] state, next_state;

   
    always @(posedge ACLK or negedge ARESETn) begin
        if (!ARESETn)
            state <= IDLE;
        else
            state <= next_state;
    end

   
    always @(*) begin
        next_state = state;
        case (state)
            IDLE:    begin
                         if (start_write) next_state = WR_ADDR;
                         else if (start_read) next_state = RD_ADDR;
                     end
            WR_ADDR: if (AWREADY && AWVALID) next_state = WR_DATA;
            WR_DATA: if (WREADY  && WVALID)  next_state = WR_RESP;
            WR_RESP: if (BVALID)             next_state = IDLE;
            RD_ADDR: if (ARREADY && ARVALID) next_state = RD_DATA;
            RD_DATA: if (RVALID)             next_state = IDLE;
            default: next_state = IDLE;
        endcase
    end

    
    always @(posedge ACLK or negedge ARESETn) begin
        if (!ARESETn) begin
            AWADDR  <= 0; AWVALID <= 0;
            WDATA   <= 0; WSTRB   <= 0; WVALID  <= 0;
            BREADY  <= 0;
            ARADDR  <= 0; ARVALID <= 0;
            RREADY  <= 0;
            data_out<= 0; done    <= 0;
        end else begin
            done <= 0;
            case (state)
                IDLE: begin
                    if (start_write) begin
                        AWADDR  <= addr_in;
                        AWVALID <= 1;
                        WDATA   <= data_in;
                        WSTRB   <= 4'b1111;
                    end
                    if (start_read) begin
                        ARADDR  <= addr_in;
                        ARVALID <= 1;
                        RREADY  <= 1;
                    end
                end
                WR_ADDR: begin
                    if (AWREADY) begin
                        AWVALID <= 0;
                        WVALID  <= 1;
                    end
                end
                WR_DATA: begin
                    if (WREADY) begin
                        WVALID <= 0;
                        BREADY <= 1;
                    end
                end
                WR_RESP: begin
                    if (BVALID) begin
                        BREADY <= 0;
                        done   <= 1;
                    end
                end
                RD_ADDR: begin
                    if (ARREADY) ARVALID <= 0;
                end
                RD_DATA: begin
                    if (RVALID) begin
                        data_out <= RDATA;
                        RREADY   <= 0;
                        done     <= 1;
                    end
                end
            endcase
        end
    end

endmodule
